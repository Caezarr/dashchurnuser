# Requesty API
REQUESTY_KEY=

# Sync period for Requesty (e.g. 30d)
SYNC_PERIOD=30d

# Dashboard auth
AUTH_TOKEN=

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://langfuse.meetwonka.com
# Limiter la charge sur l'API (sync churn par morceaux)
# LF_TRACES_PAGE_SIZE=50
# LF_TRACES_SLEEP=1.5
# LF_TRACES_CHUNK_PAGES=15

# Wonka MongoDB — obligatoire pour afficher email + org sur le churn
# Sans cette ligne, le dashboard affiche « — » et une bannière d’avertissement.
# Le fichier .env est chargé automatiquement au démarrage du collector.
# Voir MONGODB_STRUCTURE.md
WONKA_MONGO_URI=
WONKA_MONGO_DB=wonkachat-prod
# Si SSL échoue (CERTIFICATE_VERIFY_FAILED) : certifi est utilisé si installé ;
# en dernier recours pour dev uniquement : WONKA_MONGO_TLS_INSECURE=1
# Churn (agrégation messages) — optionnel
# WONKA_CHURN_MESSAGES_LOOKBACK_DAYS=90
# WONKA_CHURN_USER_MESSAGES_ONLY=1
# WONKA_CHURN_MAX_TIME_MS=180000
